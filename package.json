{
  "name": "auto-content-pipeline",
  "version": "1.3.0",
  "description": "社媒全自动流水线 — 知乎/小红书/抖音/公众号(baoyu官方API+PVA)",
  "dependencies": {
    "@panda-video-automation/pva": "latest"
  },
  "scripts": {
    "check": "bash scripts/check-deps.sh",
    "setup": "bash scripts/install-deps.sh",
    "setup:win": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "tool:install": "powershell -ExecutionPolicy Bypass -File scripts/install-tool-deps.ps1",
    "skills:register": "powershell -ExecutionPolicy Bypass -File scripts/register-skills.ps1",
    "wechat:install": "npm run tool:install; npm run skills:register",
    "image:check-key": "uv run python skills/image/scripts/cli.py check-key",
    "image:generate": "uv run python skills/image/scripts/cli.py generate",
    "douyin:login": "npx @panda-video-automation/pva douyin login",
    "douyin:upload": "npx @panda-video-automation/pva douyin upload",
    "postinstall": "node skills/youtube/scripts/patch-pva-i18n.mjs",
    "youtube:login": "node skills/youtube/scripts/cli.mjs login",
    "youtube:publish": "node skills/youtube/scripts/cli.mjs publish",
    "youtube:upload": "node skills/youtube/scripts/cli.mjs publish",
    "youtube:pipeline": "node skills/youtube/scripts/cli.mjs pipeline",
    "youtube:check-login": "node skills/youtube/scripts/cli.mjs check-login",
    "youtube:create-video": "node skills/youtube/scripts/cli.mjs create-video",
    "youtube:patch-pva": "node skills/youtube/scripts/patch-pva-i18n.mjs",
    "linkedin:login": "node skills/linkedin/scripts/cli.mjs login",
    "linkedin:publish": "node skills/linkedin/scripts/cli.mjs publish",
    "linkedin:check-login": "node skills/linkedin/scripts/cli.mjs check-login",
    "tiktok:login": "uv run python skills/tiktok/scripts/cli.py login",
    "tiktok:publish": "uv run python skills/tiktok/scripts/cli.py publish",
    "tiktok:check-login": "uv run python skills/tiktok/scripts/cli.py check-login",
    "x:login": "node skills/x/scripts/cli.mjs login",
    "x:publish": "node skills/x/scripts/cli.mjs publish",
    "x:check-login": "node skills/x/scripts/cli.mjs check-login",
    "x:preflight": "node skills/x/scripts/cli.mjs preflight",
    "overseas:install": "powershell -ExecutionPolicy Bypass -File scripts/install-overseas-tools.ps1"
  }
}
