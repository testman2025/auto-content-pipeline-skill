# Hermes 环境变量模板（复制到 Hermes .env，勿提交真实密钥）
# 查看路径: hermes config env-path

# tokenware 生图 / OpenAI 兼容 API
OPENAI_API_KEY=your_tokenware_api_key_here

# 公众号 — baoyu-post-to-wechat + 微信官方 API（固定方案）
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# 抖音 — PVA 浏览器登录，无需开放平台 Key（固定方案）
# 首次: npm run douyin:login

# LinkedIn — 官方 OAuth + Posts API（个人号）
# 见 skills/linkedin/references/linkedin-api-setup.md
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://127.0.0.1:8765/callback
LINKEDIN_API_VERSION=202601
